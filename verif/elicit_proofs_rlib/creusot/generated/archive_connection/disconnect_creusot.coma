  /\ ([@stop_split] [@expl:disconnect 'proof' type invariant] [%#sarchive_connection'6] inv_Established_ArchiveConnectionConsistent proof)
  /\ ([@stop_split] [@expl:disconnect requires] [%#sarchive_connection'7] archive_connection_consistent_creusot state)}
  any
  [ return (result: tup2_ArchiveConnectionState_Established_ArchiveConnectionConsistent) ->
  {[@stop_split] [@expl:disconnect ensures] ([@stop_split] [@expl:disconnect result type invariant] [%#sconnection] inv_tup2_ArchiveConnectionState_Established_ArchiveConnectionConsistent result)
    /\ ([@stop_split] [@expl:disconnect ensures] [%#sarchive_connection'8] archive_connection_consistent_creusot result.f0)}
    (! return {result}) ]

