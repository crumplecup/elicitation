use creusot.prelude.Any

type t_String

type t_BackendKind = Postgres | Sqlite | Mysql | Redb | Unknown

type t_Option_String = None | Some t_String

type t_DatabaseDescriptor = {
  connection_id: t_String;
  db_name: t_String;
  version: t_Option_String;
  backend: t_BackendKind }

type t_ArchiveConnectionState =
  | Disconnected
  | Connecting t_String t_BackendKind
  | SqlConnected t_DatabaseDescriptor
  | KvConnected t_String
  | Reconnecting t_DatabaseDescriptor
  | ConnectionError t_String

type t_Established_ArchiveConnectionConsistent

type tup2_ArchiveConnectionState_Established_ArchiveConnectionConsistent = {
  f0: t_ArchiveConnectionState;
  f1: t_Established_ArchiveConnectionConsistent }

predicate inv_String (_1: t_String)

predicate inv_Option_String (_1: t_Option_String)

axiom inv_axiom [@rewrite]: forall x: t_Option_String [inv_Option_String x]. inv_Option_String x
    = match x with
      | None -> true
      | Some f0'0 -> inv_String f0'0
      end

predicate inv_DatabaseDescriptor (_1: t_DatabaseDescriptor)

axiom inv_axiom'0 [@rewrite]: forall x: t_DatabaseDescriptor [inv_DatabaseDescriptor x]. inv_DatabaseDescriptor x
    = (inv_String x.connection_id /\ inv_String x.db_name /\ inv_Option_String x.version)

predicate inv_ArchiveConnectionState (_1: t_ArchiveConnectionState)

axiom inv_axiom'1 [@rewrite]:
  forall x: t_ArchiveConnectionState [inv_ArchiveConnectionState x]. inv_ArchiveConnectionState x
    = match x with
      | Disconnected -> true
      | Connecting profile_name backend'0 -> inv_String profile_name
      | SqlConnected db -> inv_DatabaseDescriptor db
      | KvConnected path -> inv_String path
      | Reconnecting db -> inv_DatabaseDescriptor db
      | ConnectionError message -> inv_String message
      end

predicate inv_Established_ArchiveConnectionConsistent (_1: t_Established_ArchiveConnectionConsistent)

predicate archive_connection_consistent [#"/home/erik/repos/elicitation/crates/elicit_proofs/src/creusot/generated/archive_connection.rs" 24 0 24 77] (_state: t_ArchiveConnectionState) =
  [%#sarchive_connection'11] true

predicate inv_tup2_ArchiveConnectionState_Established_ArchiveConnectionConsistent [@inline:trivial] (_1: tup2_ArchiveConnectionState_Established_ArchiveConnectionConsistent) =
  inv_ArchiveConnectionState _1.f0 /\ inv_Established_ArchiveConnectionConsistent _1.f1

meta "rewrite_def" predicate inv_tup2_ArchiveConnectionState_Established_ArchiveConnectionConsistent

let rec connection_error (state: t_ArchiveConnectionState) (proof: t_Established_ArchiveConnectionConsistent)
  (message: t_String) (return (x: tup2_ArchiveConnectionState_Established_ArchiveConnectionConsistent)) =
  {[@stop_split] [@expl:connection_error requires] ([@stop_split] [@expl:connection_error 'state' type invariant] [%#sarchive_connection'6] inv_ArchiveConnectionState state)
  /\ ([@stop_split] [@expl:connection_error 'proof' type invariant] [%#sarchive_connection'7] inv_Established_ArchiveConnectionConsistent proof)
  /\ ([@stop_split] [@expl:connection_error 'message' type invariant] [%#sarchive_connection'8] inv_String message)
  /\ ([@stop_split] [@expl:connection_error requires] [%#sarchive_connection'9] archive_connection_consistent state)}
  any
  [ return (result: tup2_ArchiveConnectionState_Established_ArchiveConnectionConsistent) ->
  {[@stop_split] [@expl:connection_error ensures] ([@stop_split] [@expl:connection_error result type invariant] [%#sconnection] inv_tup2_ArchiveConnectionState_Established_ArchiveConnectionConsistent result)
    /\ ([@stop_split] [@expl:connection_error ensures] [%#sarchive_connection'10] archive_connection_consistent result.f0)}
    (! return {result}) ]

