use creusot.prelude.Any
use seq.Seq
use creusot.prelude.Char
use int.Int

type t_String

type t_MiniConnState = Disconnected | Connecting t_String | Connected t_String | Error t_String

predicate inv_String (_1: t_String)

function view_String (self: t_String) : Seq.seq Char.t

predicate inv_MiniConnState (_1: t_MiniConnState)

axiom inv_axiom [@rewrite]: forall x: t_MiniConnState [inv_MiniConnState x]. inv_MiniConnState x
    = match x with
      | Disconnected -> true
      | Connecting name -> inv_String name
      | Connected name -> inv_String name
      | Error message -> inv_String message
      end

predicate c10_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level10.rs" 84 0 84 48] (s: t_MiniConnState) =
  [%#slevel10'3] match s with
    | Disconnected -> true
    | Connecting name -> Seq.length (view_String name) > 0
    | Connected name -> Seq.length (view_String name) > 0
    | Error message -> Seq.length (view_String message) > 0
    end

meta "compute_max_steps" 1000000

meta "select_lsinst" "all"

let rec c10_mk_connected
  [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level10.rs" 109 0 109 54] (name: t_String)
  (return (x: t_MiniConnState)) =
  {[@stop_split] [@expl:c10_mk_connected requires] ([@stop_split] [@expl:c10_mk_connected 'name' type invariant] [%#slevel10] inv_String name)
  /\ ([@stop_split] [@expl:c10_mk_connected requires] [%#slevel10'0] Seq.length (view_String name) > 0)}
  (! bb0
  [ bb0 = s0 [ s0 = [ &_ret <- Connected name ] s1 | s1 = return {_ret} ] ]
  [ & _ret: t_MiniConnState = Any.any_l () | & name: t_String = name ])
  [ return (result: t_MiniConnState) ->
  {[@stop_split] [@expl:c10_mk_connected ensures] ([@stop_split] [@expl:c10_mk_connected result type invariant] [%#slevel10'1] inv_MiniConnState result)
    /\ ([@stop_split] [@expl:c10_mk_connected ensures] [%#slevel10'2] c10_consistent result)}
    (! return {result}) ]
