use seq.Seq
use creusot.prelude.Char
use creusot.prelude.Any
use int.Int

type t_String

type t_MiniConnState = Disconnected | Connecting t_String | Connected t_String | Error t_String

predicate inv_String (_1: t_String)

predicate inv_MiniConnState (_1: t_MiniConnState)

axiom inv_axiom [@rewrite]: forall x: t_MiniConnState [inv_MiniConnState x]. inv_MiniConnState x
    = match x with
      | Disconnected -> true
      | Connecting name -> inv_String name
      | Connected name -> inv_String name
      | Error message -> inv_String message
      end

function view_String (self: t_String) : Seq.seq Char.t

predicate c10_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level10.rs" 83 0 83 48] (s: t_MiniConnState) =
  [%#slevel10'19] match s with
    | Disconnected -> true
    | Connecting name -> Seq.length (view_String name) > 0
    | Connected name -> Seq.length (view_String name) > 0
    | Error message -> Seq.length (view_String message) > 0
    end

let rec c10_begin (_s: t_MiniConnState) (name: t_String) (return (x: t_MiniConnState)) =
  {[@stop_split] [@expl:c10_begin requires] ([@stop_split] [@expl:c10_begin '_s' type invariant] [%#slevel10'6] inv_MiniConnState _s)
  /\ ([@stop_split] [@expl:c10_begin 'name' type invariant] [%#slevel10'7] inv_String name)
  /\ ([@stop_split] [@expl:c10_begin requires] [%#slevel10'8] Seq.length (view_String name) > 0)}
  any
  [ return (result: t_MiniConnState) ->
  {[@stop_split] [@expl:c10_begin ensures] ([@stop_split] [@expl:c10_begin result type invariant] [%#slevel10'9] inv_MiniConnState result)
    /\ ([@stop_split] [@expl:c10_begin ensures] [%#slevel10'10] c10_consistent result)}
    (! return {result}) ]

let rec c10_succeed (s: t_MiniConnState) (return (x: t_MiniConnState)) =
  {[@stop_split] [@expl:c10_succeed requires] ([@stop_split] [@expl:c10_succeed 's' type invariant] [%#slevel10'11] inv_MiniConnState s)
  /\ ([@stop_split] [@expl:c10_succeed requires] [%#slevel10'12] c10_consistent s)}
  any
  [ return (result: t_MiniConnState) ->
  {[@stop_split] [@expl:c10_succeed ensures] ([@stop_split] [@expl:c10_succeed result type invariant] [%#slevel10'13] inv_MiniConnState result)
    /\ ([@stop_split] [@expl:c10_succeed ensures] [%#slevel10'14] c10_consistent result)}
    (! return {result}) ]

let rec c10_disconnect (s: t_MiniConnState) (return (x: t_MiniConnState)) =
  {[@stop_split] [@expl:c10_disconnect requires] ([@stop_split] [@expl:c10_disconnect 's' type invariant] [%#slevel10'15] inv_MiniConnState s)
  /\ ([@stop_split] [@expl:c10_disconnect requires] [%#slevel10'16] c10_consistent s)}
  any
  [ return (result: t_MiniConnState) ->
  {[@stop_split] [@expl:c10_disconnect ensures] ([@stop_split] [@expl:c10_disconnect result type invariant] [%#slevel10'17] inv_MiniConnState result)
    /\ ([@stop_split] [@expl:c10_disconnect ensures] [%#slevel10'18] c10_consistent result)}
    (! return {result}) ]

meta "compute_max_steps" 1000000

meta "select_lsinst" "all"

let rec c10_full_lifecycle
  [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level10.rs" 197 0 197 56] (name: t_String)
  (return (x: t_MiniConnState)) =
  {[@stop_split] [@expl:c10_full_lifecycle requires] ([@stop_split] [@expl:c10_full_lifecycle 'name' type invariant] [%#slevel10'2] inv_String name)
  /\ ([@stop_split] [@expl:c10_full_lifecycle requires] [%#slevel10'3] Seq.length (view_String name) > 0)}
  (! bb0
  [ bb0 = s0'0
    [ s0'0 = [ &s0 <- Disconnected ] s1'0
    | s1'0 = c10_begin [%#slevel10] {s0} {name} (fun (_x: t_MiniConnState) -> [ &s1 <- _x ] s2'0)
    | s2'0 = c10_succeed [%#slevel10'0] {s1} (fun (_x: t_MiniConnState) -> [ &s2 <- _x ] s3)
    | s3 = c10_disconnect [%#slevel10'1] {s2} (fun (_x: t_MiniConnState) -> [ &_ret <- _x ] s4)
    | s4 = return {_ret} ] ]
  [ & _ret: t_MiniConnState = Any.any_l ()
  | & name: t_String = name
  | & s0: t_MiniConnState = Any.any_l ()
  | & s1: t_MiniConnState = Any.any_l ()
  | & s2: t_MiniConnState = Any.any_l () ])
  [ return (result: t_MiniConnState) ->
  {[@stop_split] [@expl:c10_full_lifecycle ensures] ([@stop_split] [@expl:c10_full_lifecycle result type invariant] [%#slevel10'4] inv_MiniConnState result)
    /\ ([@stop_split] [@expl:c10_full_lifecycle ensures] [%#slevel10'5] c10_consistent result)}
    (! return {result}) ]
