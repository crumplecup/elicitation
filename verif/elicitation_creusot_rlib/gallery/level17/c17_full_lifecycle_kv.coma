use seq.Seq
use creusot.prelude.Char
use creusot.prelude.Any
use int.Int

type t_String

type t_C17BackendKind = Sql | Kv

type t_C17ConnState =
  | Disconnected
  | Connecting t_String t_C17BackendKind
  | SqlConnected t_String
  | KvConnected t_String
  | ConnectionError t_String

predicate inv_String (_1: t_String)

predicate inv_C17ConnState (_1: t_C17ConnState)

axiom inv_axiom [@rewrite]: forall x: t_C17ConnState [inv_C17ConnState x]. inv_C17ConnState x
    = match x with
      | Disconnected -> true
      | Connecting profile_name backend -> inv_String profile_name
      | SqlConnected tag -> inv_String tag
      | KvConnected path -> inv_String path
      | ConnectionError message -> inv_String message
      end

function view_String (self: t_String) : Seq.seq Char.t

predicate c17_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level17.rs" 115 0 115 47] (s: t_C17ConnState) =
  [%#slevel17'35] match s with
    | Disconnected -> true
    | Connecting profile_name _ -> Seq.length (view_String profile_name) > 0
    | SqlConnected tag -> Seq.length (view_String tag) > 0
    | KvConnected path -> Seq.length (view_String path) > 0
    | ConnectionError message -> Seq.length (view_String message) > 0
    end

predicate c17_is_disconnected [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level17.rs" 128 0 128 52] (s: t_C17ConnState) =
  [%#slevel17'36] match s with
    | Disconnected -> true
    | _ -> false
    end

let rec c17_new (return (x: t_C17ConnState)) = any
  [ return (result: t_C17ConnState) ->
  {[@stop_split] [@expl:c17_new ensures] ([@stop_split] [@expl:c17_new result type invariant] [%#slevel17'10] inv_C17ConnState result)
    /\ ([@stop_split] [@expl:c17_new ensures #0] [%#slevel17'11] c17_consistent result)
    /\ ([@stop_split] [@expl:c17_new ensures #1] [%#slevel17'12] c17_is_disconnected result)}
    (! return {result}) ]

predicate c17_is_connecting [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level17.rs" 133 0 133 50] (s: t_C17ConnState) =
  [%#slevel17'37] match s with
    | Connecting _ _ -> true
    | _ -> false
    end

predicate c17_backend_is_kv [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level17.rs" 163 0 163 50] (s: t_C17ConnState) =
  [%#slevel17'38] match s with
    | Connecting _ (Kv) -> true
    | _ -> false
    end

let rec c17_begin_kv (s: t_C17ConnState) (profile_name: t_String) (return (x: t_C17ConnState)) =
  {[@stop_split] [@expl:c17_begin_kv requires] ([@stop_split] [@expl:c17_begin_kv 's' type invariant] [%#slevel17'13] inv_C17ConnState s)
  /\ ([@stop_split] [@expl:c17_begin_kv 'profile_name' type invariant] [%#slevel17'14] inv_String profile_name)
  /\ ([@stop_split] [@expl:c17_begin_kv requires #0] [%#slevel17'15] c17_is_disconnected s)
  /\ ([@stop_split] [@expl:c17_begin_kv requires #1] [%#slevel17'16] Seq.length (view_String profile_name) > 0)}
  any
  [ return (result: t_C17ConnState) ->
  {[@stop_split] [@expl:c17_begin_kv ensures] ([@stop_split] [@expl:c17_begin_kv result type invariant] [%#slevel17'17] inv_C17ConnState result)
    /\ ([@stop_split] [@expl:c17_begin_kv ensures #0] [%#slevel17'18] c17_consistent result)
    /\ ([@stop_split] [@expl:c17_begin_kv ensures #1] [%#slevel17'19] c17_is_connecting result)
    /\ ([@stop_split] [@expl:c17_begin_kv ensures #2] [%#slevel17'20] c17_backend_is_kv result)}
    (! return {result}) ]

predicate c17_is_kv_connected [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level17.rs" 143 0 143 52] (s: t_C17ConnState) =
  [%#slevel17'39] match s with
    | KvConnected _ -> true
    | _ -> false
    end

let rec c17_finish_kv (s: t_C17ConnState) (path: t_String) (return (x: t_C17ConnState)) =
  {[@stop_split] [@expl:c17_finish_kv requires] ([@stop_split] [@expl:c17_finish_kv 's' type invariant] [%#slevel17'21] inv_C17ConnState s)
  /\ ([@stop_split] [@expl:c17_finish_kv 'path' type invariant] [%#slevel17'22] inv_String path)
  /\ ([@stop_split] [@expl:c17_finish_kv requires #0] [%#slevel17'23] c17_consistent s)
  /\ ([@stop_split] [@expl:c17_finish_kv requires #1] [%#slevel17'24] c17_backend_is_kv s)
  /\ ([@stop_split] [@expl:c17_finish_kv requires #2] [%#slevel17'25] Seq.length (view_String path) > 0)}
  any
  [ return (result: t_C17ConnState) ->
  {[@stop_split] [@expl:c17_finish_kv ensures] ([@stop_split] [@expl:c17_finish_kv result type invariant] [%#slevel17'26] inv_C17ConnState result)
    /\ ([@stop_split] [@expl:c17_finish_kv ensures #0] [%#slevel17'27] c17_consistent result)
    /\ ([@stop_split] [@expl:c17_finish_kv ensures #1] [%#slevel17'28] c17_is_kv_connected result)}
    (! return {result}) ]

predicate c17_is_disconnectable [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level17.rs" 174 0 174 54] (s: t_C17ConnState) =
  [%#slevel17'40] match s with
    | SqlConnected _ -> true
    | KvConnected _ -> true
    | ConnectionError _ -> true
    | _ -> false
    end

let rec c17_disconnect (s: t_C17ConnState) (return (x: t_C17ConnState)) =
  {[@stop_split] [@expl:c17_disconnect requires] ([@stop_split] [@expl:c17_disconnect 's' type invariant] [%#slevel17'29] inv_C17ConnState s)
  /\ ([@stop_split] [@expl:c17_disconnect requires #0] [%#slevel17'30] c17_consistent s)
  /\ ([@stop_split] [@expl:c17_disconnect requires #1] [%#slevel17'31] c17_is_disconnectable s)}
  any
  [ return (result: t_C17ConnState) ->
  {[@stop_split] [@expl:c17_disconnect ensures] ([@stop_split] [@expl:c17_disconnect result type invariant] [%#slevel17'32] inv_C17ConnState result)
    /\ ([@stop_split] [@expl:c17_disconnect ensures #0] [%#slevel17'33] c17_consistent result)
    /\ ([@stop_split] [@expl:c17_disconnect ensures #1] [%#slevel17'34] c17_is_disconnected result)}
    (! return {result}) ]

meta "compute_max_steps" 1000000

meta "select_lsinst" "all"

let rec c17_full_lifecycle_kv
  [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level17.rs" 290 0 290 80]
  (profile_name: t_String) (path: t_String) (return (x: t_C17ConnState)) =
  {[@stop_split] [@expl:c17_full_lifecycle_kv requires] ([@stop_split] [@expl:c17_full_lifecycle_kv 'profile_name' type invariant] [%#slevel17'3] inv_String profile_name)
  /\ ([@stop_split] [@expl:c17_full_lifecycle_kv 'path' type invariant] [%#slevel17'4] inv_String path)
  /\ ([@stop_split] [@expl:c17_full_lifecycle_kv requires #0] [%#slevel17'5] Seq.length (view_String profile_name) > 0)
  /\ ([@stop_split] [@expl:c17_full_lifecycle_kv requires #1] [%#slevel17'6] Seq.length (view_String path) > 0)}
  (! bb0
  [ bb0 = s0'0
    [ s0'0 = c17_new [%#slevel17] (fun (_x: t_C17ConnState) -> [ &s0 <- _x ] s1'0)
    | s1'0 = c17_begin_kv [%#slevel17'0] {s0} {profile_name} (fun (_x: t_C17ConnState) -> [ &s1 <- _x ] s2'0)
    | s2'0 = c17_finish_kv [%#slevel17'1] {s1} {path} (fun (_x: t_C17ConnState) -> [ &s2 <- _x ] s3)
    | s3 = c17_disconnect [%#slevel17'2] {s2} (fun (_x: t_C17ConnState) -> [ &_ret <- _x ] s4)
    | s4 = return {_ret} ] ]
  [ & _ret: t_C17ConnState = Any.any_l ()
  | & profile_name: t_String = profile_name
  | & path: t_String = path
  | & s0: t_C17ConnState = Any.any_l ()
  | & s1: t_C17ConnState = Any.any_l ()
  | & s2: t_C17ConnState = Any.any_l () ])
  [ return (result: t_C17ConnState) ->
  {[@stop_split] [@expl:c17_full_lifecycle_kv ensures] ([@stop_split] [@expl:c17_full_lifecycle_kv result type invariant] [%#slevel17'7] inv_C17ConnState result)
    /\ ([@stop_split] [@expl:c17_full_lifecycle_kv ensures #0] [%#slevel17'8] c17_consistent result)
    /\ ([@stop_split] [@expl:c17_full_lifecycle_kv ensures #1] [%#slevel17'9] c17_is_disconnected result)}
    (! return {result}) ]
