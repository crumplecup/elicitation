let rec c17_full_lifecycle_sql
  [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level17.rs" 270 0 270 80]
  (profile_name: t_String) (tag: t_String) (return (x: t_C17ConnState)) =
  {[@stop_split] [@expl:c17_full_lifecycle_sql requires] ([@stop_split] [@expl:c17_full_lifecycle_sql 'profile_name' type invariant] [%#slevel17'3] inv_String profile_name)
