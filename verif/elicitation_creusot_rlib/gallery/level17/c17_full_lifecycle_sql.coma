use seq.Seq
use creusot.prelude.Char
use creusot.prelude.Any
use int.Int

type t_String

type t_C17BackendKind = Sql | Kv

type t_C17ConnState =
  | Disconnected
  | Connecting t_String t_C17BackendKind
  | SqlConnected t_String
  | KvConnected t_String
  | ConnectionError t_String

predicate inv_String (_1: t_String)

predicate inv_C17ConnState (_1: t_C17ConnState)

axiom inv_axiom [@rewrite]: forall x: t_C17ConnState [inv_C17ConnState x]. inv_C17ConnState x
    = match x with
      | Disconnected -> true
      | Connecting profile_name backend -> inv_String profile_name
      | SqlConnected tag -> inv_String tag
      | KvConnected path -> inv_String path
      | ConnectionError message -> inv_String message
      end

function view_String (self: t_String) : Seq.seq Char.t

predicate c17_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level17.rs" 115 0 115 47] (s: t_C17ConnState) =
  [%#slevel17'35] match s with
    | Disconnected -> true
    | Connecting profile_name _ -> Seq.length (view_String profile_name) > 0
    | SqlConnected tag -> Seq.length (view_String tag) > 0
    | KvConnected path -> Seq.length (view_String path) > 0
    | ConnectionError message -> Seq.length (view_String message) > 0
    end

predicate c17_is_disconnected [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level17.rs" 128 0 128 52] (s: t_C17ConnState) =
  [%#slevel17'36] match s with
    | Disconnected -> true
    | _ -> false
    end

let rec c17_new (return (x: t_C17ConnState)) = any
  [ return (result: t_C17ConnState) ->
  {[@stop_split] [@expl:c17_new ensures] ([@stop_split] [@expl:c17_new result type invariant] [%#slevel17'10] inv_C17ConnState result)
    /\ ([@stop_split] [@expl:c17_new ensures #0] [%#slevel17'11] c17_consistent result)
    /\ ([@stop_split] [@expl:c17_new ensures #1] [%#slevel17'12] c17_is_disconnected result)}
    (! return {result}) ]

predicate c17_is_connecting [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level17.rs" 133 0 133 50] (s: t_C17ConnState) =
  [%#slevel17'37] match s with
    | Connecting _ _ -> true
    | _ -> false
    end

predicate c17_backend_is_sql [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level17.rs" 152 0 152 51] (s: t_C17ConnState) =
  [%#slevel17'38] match s with
    | Connecting _ (Sql) -> true
    | _ -> false
    end

let rec c17_begin_sql (s: t_C17ConnState) (profile_name: t_String) (return (x: t_C17ConnState)) =
  {[@stop_split] [@expl:c17_begin_sql requires] ([@stop_split] [@expl:c17_begin_sql 's' type invariant] [%#slevel17'13] inv_C17ConnState s)
  /\ ([@stop_split] [@expl:c17_begin_sql 'profile_name' type invariant] [%#slevel17'14] inv_String profile_name)
  /\ ([@stop_split] [@expl:c17_begin_sql requires #0] [%#slevel17'15] c17_is_disconnected s)
  /\ ([@stop_split] [@expl:c17_begin_sql requires #1] [%#slevel17'16] Seq.length (view_String profile_name) > 0)}
  any
  [ return (result: t_C17ConnState) ->
  {[@stop_split] [@expl:c17_begin_sql ensures] ([@stop_split] [@expl:c17_begin_sql result type invariant] [%#slevel17'17] inv_C17ConnState result)
    /\ ([@stop_split] [@expl:c17_begin_sql ensures #0] [%#slevel17'18] c17_consistent result)
    /\ ([@stop_split] [@expl:c17_begin_sql ensures #1] [%#slevel17'19] c17_is_connecting result)
    /\ ([@stop_split] [@expl:c17_begin_sql ensures #2] [%#slevel17'20] c17_backend_is_sql result)}
    (! return {result}) ]

predicate c17_is_sql_connected [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level17.rs" 138 0 138 53] (s: t_C17ConnState) =
  [%#slevel17'39] match s with
    | SqlConnected _ -> true
    | _ -> false
    end

let rec c17_finish_sql (s: t_C17ConnState) (tag: t_String) (return (x: t_C17ConnState)) =
  {[@stop_split] [@expl:c17_finish_sql requires] ([@stop_split] [@expl:c17_finish_sql 's' type invariant] [%#slevel17'21] inv_C17ConnState s)
  /\ ([@stop_split] [@expl:c17_finish_sql 'tag' type invariant] [%#slevel17'22] inv_String tag)
  /\ ([@stop_split] [@expl:c17_finish_sql requires #0] [%#slevel17'23] c17_consistent s)
  /\ ([@stop_split] [@expl:c17_finish_sql requires #1] [%#slevel17'24] c17_backend_is_sql s)
  /\ ([@stop_split] [@expl:c17_finish_sql requires #2] [%#slevel17'25] Seq.length (view_String tag) > 0)}
  any
  [ return (result: t_C17ConnState) ->
