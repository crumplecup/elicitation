let rec c16_full_lifecycle
  [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level16.rs" 309 0 314 17]
  (profile_name: t_String) (backend_tag: t_String) (desc1: t_C16Descriptor) (desc2: t_C16Descriptor)
  (return (x: t_C16ConnState)) =
  {[@stop_split] [@expl:c16_full_lifecycle requires] ([@stop_split] [@expl:c16_full_lifecycle 'profile_name' type invariant] [%#slevel16'5] inv_String profile_name)
  /\ ([@stop_split] [@expl:c16_full_lifecycle 'backend_tag' type invariant] [%#slevel16'6] inv_String backend_tag)
  /\ ([@stop_split] [@expl:c16_full_lifecycle 'desc1' type invariant] [%#slevel16'7] inv_C16Descriptor desc1)
  /\ ([@stop_split] [@expl:c16_full_lifecycle 'desc2' type invariant] [%#slevel16'8] inv_C16Descriptor desc2)
  /\ ([@stop_split] [@expl:c16_full_lifecycle requires #0] [%#slevel16'9] Seq.length (view_String profile_name) > 0)
  /\ ([@stop_split] [@expl:c16_full_lifecycle requires #1] [%#slevel16'10] Seq.length (view_String backend_tag) > 0)
  /\ ([@stop_split] [@expl:c16_full_lifecycle requires #2] [%#slevel16'11] c16_desc_consistent desc1)
  /\ ([@stop_split] [@expl:c16_full_lifecycle requires #3] [%#slevel16'12] c16_desc_consistent desc2)}
  (! bb0
  [ bb0 = s0'0
    [ s0'0 = c16_new [%#slevel16] (fun (_x: t_C16ConnState) -> [ &s0 <- _x ] s1'0)
    | s1'0 = c16_begin_connect [%#slevel16'0] {s0} {profile_name} {backend_tag}
        (fun (_x: t_C16ConnState) -> [ &s1 <- _x ] s2'0)
    | s2'0 = c16_finish_sql [%#slevel16'1] {s1} {desc1} (fun (_x: t_C16ConnState) -> [ &s2 <- _x ] s3'0)
    | s3'0 = c16_reconnect_sql [%#slevel16'2] {s2} (fun (_x: t_C16ConnState) -> [ &s3 <- _x ] s4'0)
    | s4'0 = c16_finish_reconnect_sql [%#slevel16'3] {s3} {desc2} (fun (_x: t_C16ConnState) -> [ &s4 <- _x ] s5)
    | s5 = c16_disconnect [%#slevel16'4] {s4} (fun (_x: t_C16ConnState) -> [ &_ret <- _x ] s6)
    | s6 = return {_ret} ] ]
  [ & _ret: t_C16ConnState = Any.any_l ()
  | & profile_name: t_String = profile_name
  | & backend_tag: t_String = backend_tag
  | & desc1: t_C16Descriptor = desc1
  | & desc2: t_C16Descriptor = desc2
  | & s0: t_C16ConnState = Any.any_l ()
  | & s1: t_C16ConnState = Any.any_l ()
  | & s2: t_C16ConnState = Any.any_l ()
  | & s3: t_C16ConnState = Any.any_l ()
  | & s4: t_C16ConnState = Any.any_l () ])
  [ return (result: t_C16ConnState) ->
  {[@stop_split] [@expl:c16_full_lifecycle ensures] ([@stop_split] [@expl:c16_full_lifecycle result type invariant] [%#slevel16'13] inv_C16ConnState result)
