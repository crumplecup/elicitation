  [ & _ret: t_Counter = Any.any_l () | & c: t_Counter = c | & _5: bool = Any.any_l () | & _7: bool = Any.any_l () ])
  [ return (result: t_Counter) -> {[@stop_split] [@expl:c2_clamp_to_byte ensures] [%#slevel2'4] c2_in_byte_range result}
