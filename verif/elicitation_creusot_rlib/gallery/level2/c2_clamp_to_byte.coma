type t_Counter = { count: Int64.t }

predicate c2_in_byte_range [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level2.rs" 54 0 54 44] (c: t_Counter) =
  [%#slevel2'5] Int64.to_int c.count >= 0 /\ Int64.to_int c.count <= 255

meta "compute_max_steps" 1000000

