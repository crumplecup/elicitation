  [ bb0 = s0
    [ s0 = [ &_5 <- Int64.lt c.count ([%#slevel2] (0: Int64.t)) ] s1
    | s1 = any [ br0 -> {_5 = false} (! bb2) | br1 -> {_5} (! bb1) ] ]
  | bb1 = s0 [ s0 = [ &c <- { count = ([%#slevel2'0] (0: Int64.t)) } ] s1 | s1 = bb6 ]
  | bb2 = s0
