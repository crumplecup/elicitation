use creusot.prelude.Any
use seq.Seq
use creusot.prelude.Char
use int.Int

type t_String

type t_ConnState = Connected | Error t_String

predicate inv_String (_1: t_String)

predicate inv_ConnState (_1: t_ConnState)

axiom inv_axiom [@rewrite]: forall x: t_ConnState [inv_ConnState x]. inv_ConnState x
    = match x with
      | Connected -> true
      | Error f0 -> inv_String f0
      end

function view_String (self: t_String) : Seq.seq Char.t

predicate c5_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level5.rs" 43 0 43 43] (s: t_ConnState) =
  [%#slevel5'2] match s with
    | Connected -> true
    | Error msg -> Seq.length (view_String msg) > 0
    end

