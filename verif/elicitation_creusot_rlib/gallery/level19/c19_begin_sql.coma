    | _ -> false
    end

predicate c19_is_connecting [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level19.rs" 126 0 126 50] (s: t_C18ConnState) =
  [%#slevel19'15] match s with
