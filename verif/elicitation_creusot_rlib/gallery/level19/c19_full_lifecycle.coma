  /\ ([@stop_split] [@expl:c19_full_lifecycle requires #2] [%#slevel19'10] c19_desc_consistent desc2)}
  (! bb0
  [ bb0 = s0
    [ s0 = c19_new [%#slevel19] (fun (_x: t_C19Machine) -> [ &m0 <- _x ] s1)
    | s1 = c19_begin_sql [%#slevel19'0] {m0} {profile_name} (fun (_x: t_C19Machine) -> [ &m1 <- _x ] s2)
    | s2 = c19_finish_sql [%#slevel19'1] {m1} {desc1} (fun (_x: t_C19Machine) -> [ &m2 <- _x ] s3)
    | s3 = c19_reconnect_sql [%#slevel19'2] {m2} (fun (_x: t_C19Machine) -> [ &m3 <- _x ] s4)
    | s4 = c19_finish_reconnect_sql [%#slevel19'3] {m3} {desc2} (fun (_x: t_C19Machine) -> [ &m4 <- _x ] s5)
    | s5 = c19_disconnect [%#slevel19'4] {m4} (fun (_x: t_C19Machine) -> [ &_ret <- _x ] s6)
    | s6 = return {_ret} ] ]
  [ & _ret: t_C19Machine = Any.any_l ()
  | & profile_name: t_String = profile_name
  | & desc1: t_C18Descriptor = desc1
  | & desc2: t_C18Descriptor = desc2
  | & m0: t_C19Machine = Any.any_l ()
  | & m1: t_C19Machine = Any.any_l ()
  | & m2: t_C19Machine = Any.any_l ()
  | & m3: t_C19Machine = Any.any_l ()
  | & m4: t_C19Machine = Any.any_l () ])
  [ return (result: t_C19Machine) ->
  {[@stop_split] [@expl:c19_full_lifecycle ensures] ([@stop_split] [@expl:c19_full_lifecycle result type invariant] [%#slevel19'11] inv_C19Machine result)
    /\ ([@stop_split] [@expl:c19_full_lifecycle ensures #0] [%#slevel19'12] c19_machine_consistent result)
