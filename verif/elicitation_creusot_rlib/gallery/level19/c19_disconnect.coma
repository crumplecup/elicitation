    | KvConnected _ -> true
    | Reconnecting _ -> true
    | ConnectionError _ -> true
    | _ -> false
    end

predicate c19_is_disconnected [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level19.rs" 121 0 121 52] (s: t_C18ConnState) =
  [%#slevel19'12] match s with
