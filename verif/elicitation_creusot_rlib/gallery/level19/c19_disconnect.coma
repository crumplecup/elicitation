    end

predicate c19_machine_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level19.rs" 107 0 107 53] (m: t_C19Machine) =
  [%#slevel19'9] c19_state_consistent m.state /\ Int64.to_int m.count >= 0

constant const_MAX: Int64.t = (9223372036854775807: Int64.t)

predicate c19_count_bounded [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level19.rs" 116 0 116 48] (m: t_C19Machine) =
  [%#slevel19'10] Int64.to_int m.count < Int64.to_int const_MAX

predicate c19_is_disconnectable [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level19.rs" 153 0 153 54] (s: t_C18ConnState) =
  [%#slevel19'11] match s with
