use creusot.prelude.Any
use seq.Seq
use creusot.prelude.Char
use int.Int

type t_String

predicate inv_String (_1: t_String)

let rec from_String (value: string) (return (x: t_String)) = any
  [ return (result: t_String) -> {[@stop_split] [@expl:from result type invariant] inv_String result}
    (! return {result}) ]

function view_String (self: t_String) : Seq.seq Char.t

predicate c4_nonempty [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level4.rs" 36 0 36 38] (s: t_String) =
  [%#slevel4'4] Seq.length (view_String s) > 0

meta "compute_max_steps" 1000000

meta "select_lsinst" "all"

let rec c4_hello [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level4.rs" 46 0 46 27]
  (return (x: t_String)) = (! bb0
  [ bb0 = s0
    [ s0 = from_String [%#slevel4'0] {[%#slevel4] "hello"} (fun (_x: t_String) -> [ &_ret <- _x ] s1)
    | s1 = return {_ret} ] ] [ & _ret: t_String = Any.any_l () ])
  [ return (result: t_String) ->
  {[@stop_split] [@expl:c4_hello ensures] ([@stop_split] [@expl:c4_hello result type invariant] [%#slevel4'2] inv_String result)
    /\ ([@stop_split] [@expl:c4_hello ensures] [%#slevel4'3] c4_nonempty result)}
    (! return {result}) ]
