    /\ ([@stop_split] [@expl:c12_load ensures] [%#slevel12'31] c12_consistent result)}
    (! return {result}) ]

let rec c12_disconnect (s: t_MiniComposite) (return (x: t_MiniComposite)) =
  {[@stop_split] [@expl:c12_disconnect requires] ([@stop_split] [@expl:c12_disconnect 's' type invariant] [%#slevel12'32] inv_MiniComposite s)
  /\ ([@stop_split] [@expl:c12_disconnect requires] [%#slevel12'33] c12_consistent s)}
