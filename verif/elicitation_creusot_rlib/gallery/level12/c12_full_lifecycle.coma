let rec c12_full_lifecycle
  [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level12.rs" 279 0 279 72] (name: t_String)
  (row_count: Int64.t) (return (x: t_MiniComposite)) =
  {[@stop_split] [@expl:c12_full_lifecycle requires] ([@stop_split] [@expl:c12_full_lifecycle 'name' type invariant] [%#slevel12'4] inv_String name)
  /\ ([@stop_split] [@expl:c12_full_lifecycle requires #0] [%#slevel12'5] Seq.length (view_String name) > 0)
  /\ ([@stop_split] [@expl:c12_full_lifecycle requires #1] [%#slevel12'6] Int64.to_int row_count > 0)}
  (! bb0
  [ bb0 = s0'0
    [ s0'0 = c12_new [%#slevel12] (fun (_x: t_MiniComposite) -> [ &s0 <- _x ] s1'0)
    | s1'0 = c12_begin [%#slevel12'0] {s0} {name} (fun (_x: t_MiniComposite) -> [ &s1 <- _x ] s2'0)
    | s2'0 = c12_succeed [%#slevel12'1] {s1} (fun (_x: t_MiniComposite) -> [ &s2 <- _x ] s3'0)
    | s3'0 = c12_load [%#slevel12'2] {s2} {row_count} (fun (_x: t_MiniComposite) -> [ &s3 <- _x ] s4)
    | s4 = c12_disconnect [%#slevel12'3] {s3} (fun (_x: t_MiniComposite) -> [ &_ret <- _x ] s5)
    | s5 = return {_ret} ] ]
  [ & _ret: t_MiniComposite = Any.any_l ()
  | & name: t_String = name
  | & row_count: Int64.t = row_count
  | & s0: t_MiniComposite = Any.any_l ()
  | & s1: t_MiniComposite = Any.any_l ()
  | & s2: t_MiniComposite = Any.any_l ()
  | & s3: t_MiniComposite = Any.any_l () ])
  [ return (result: t_MiniComposite) ->
  {[@stop_split] [@expl:c12_full_lifecycle ensures] ([@stop_split] [@expl:c12_full_lifecycle result type invariant] [%#slevel12'7] inv_MiniComposite result)
    /\ ([@stop_split] [@expl:c12_full_lifecycle ensures] [%#slevel12'8] c12_consistent result)}
    (! return {result}) ]
