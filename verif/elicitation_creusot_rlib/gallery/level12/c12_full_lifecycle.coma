  /\ ([@stop_split] [@expl:c12_succeed requires #1] [%#slevel12'22] c12_is_connecting s)}
  any
  [ return (result: t_MiniComposite) ->
  {[@stop_split] [@expl:c12_succeed ensures] ([@stop_split] [@expl:c12_succeed result type invariant] [%#slevel12'23] inv_MiniComposite result)
    /\ ([@stop_split] [@expl:c12_succeed ensures #0] [%#slevel12'24] c12_consistent result)
    /\ ([@stop_split] [@expl:c12_succeed ensures #1] [%#slevel12'25] c12_is_connected result)}
    (! return {result}) ]

let rec c12_load (s: t_MiniComposite) (row_count: Int64.t) (return (x: t_MiniComposite)) =
  {[@stop_split] [@expl:c12_load requires] ([@stop_split] [@expl:c12_load 's' type invariant] [%#slevel12'26] inv_MiniComposite s)
