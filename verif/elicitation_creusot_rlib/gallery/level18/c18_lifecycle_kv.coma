use creusot.int.Int32
use seq.Seq
use creusot.prelude.Char
use creusot.prelude.Any
use int.Int

type t_String

type t_C18BackendKind = Sql | Kv

type t_C18Descriptor = { name: t_String; port: Int32.t }

type t_C18ConnState =
  | Disconnected
  | Connecting t_String t_C18BackendKind
  | SqlConnected t_C18Descriptor
  | KvConnected t_String
  | Reconnecting t_C18Descriptor
  | ConnectionError t_String

predicate inv_String (_1: t_String)

predicate inv_C18Descriptor (_1: t_C18Descriptor)

axiom inv_axiom [@rewrite]: forall x: t_C18Descriptor [inv_C18Descriptor x]. inv_C18Descriptor x = inv_String x.name

predicate inv_C18ConnState (_1: t_C18ConnState)

axiom inv_axiom'0 [@rewrite]: forall x: t_C18ConnState [inv_C18ConnState x]. inv_C18ConnState x
    = match x with
      | Disconnected -> true
      | Connecting profile_name backend -> inv_String profile_name
      | SqlConnected desc -> inv_C18Descriptor desc
      | KvConnected path -> inv_String path
      | Reconnecting desc -> inv_C18Descriptor desc
      | ConnectionError message -> inv_String message
      end

function view_String (self: t_String) : Seq.seq Char.t

predicate c18_desc_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level18.rs" 99 0 99 53] (d: t_C18Descriptor) =
  [%#slevel18'40] Seq.length (view_String d.name) > 0 /\ Int32.to_int d.port > 0

predicate c18_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level18.rs" 143 0 143 47] (s: t_C18ConnState) =
  [%#slevel18'35] match s with
    | Disconnected -> true
    | Connecting profile_name _ -> Seq.length (view_String profile_name) > 0
    | SqlConnected desc -> c18_desc_consistent desc
    | KvConnected path -> Seq.length (view_String path) > 0
    | Reconnecting desc -> c18_desc_consistent desc
    | ConnectionError message -> Seq.length (view_String message) > 0
    end

predicate c18_is_disconnected [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level18.rs" 157 0 157 52] (s: t_C18ConnState) =
  [%#slevel18'36] match s with
    | Disconnected -> true
    | _ -> false
    end

let rec c18_new (return (x: t_C18ConnState)) = any
  [ return (result: t_C18ConnState) ->
  {[@stop_split] [@expl:c18_new ensures] ([@stop_split] [@expl:c18_new result type invariant] [%#slevel18'10] inv_C18ConnState result)
    /\ ([@stop_split] [@expl:c18_new ensures #0] [%#slevel18'11] c18_consistent result)
    /\ ([@stop_split] [@expl:c18_new ensures #1] [%#slevel18'12] c18_is_disconnected result)}
    (! return {result}) ]

predicate c18_is_connecting [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level18.rs" 162 0 162 50] (s: t_C18ConnState) =
  [%#slevel18'37] match s with
    | Connecting _ _ -> true
    | _ -> false
    end

predicate c18_backend_is_kv [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level18.rs" 189 0 189 50] (s: t_C18ConnState) =
  [%#slevel18'38] match s with
    | Connecting _ (Kv) -> true
    | _ -> false
    end

let rec c18_begin_kv (s: t_C18ConnState) (profile_name: t_String) (return (x: t_C18ConnState)) =
  {[@stop_split] [@expl:c18_begin_kv requires] ([@stop_split] [@expl:c18_begin_kv 's' type invariant] [%#slevel18'13] inv_C18ConnState s)
  /\ ([@stop_split] [@expl:c18_begin_kv 'profile_name' type invariant] [%#slevel18'14] inv_String profile_name)
  /\ ([@stop_split] [@expl:c18_begin_kv requires #0] [%#slevel18'15] c18_is_disconnected s)
  /\ ([@stop_split] [@expl:c18_begin_kv requires #1] [%#slevel18'16] Seq.length (view_String profile_name) > 0)}
  any
  [ return (result: t_C18ConnState) ->
  {[@stop_split] [@expl:c18_begin_kv ensures] ([@stop_split] [@expl:c18_begin_kv result type invariant] [%#slevel18'17] inv_C18ConnState result)
    /\ ([@stop_split] [@expl:c18_begin_kv ensures #0] [%#slevel18'18] c18_consistent result)
    /\ ([@stop_split] [@expl:c18_begin_kv ensures #1] [%#slevel18'19] c18_is_connecting result)
    /\ ([@stop_split] [@expl:c18_begin_kv ensures #2] [%#slevel18'20] c18_backend_is_kv result)}
    (! return {result}) ]

predicate c18_is_disconnectable [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level18.rs" 200 0 200 54] (s: t_C18ConnState) =
  [%#slevel18'39] match s with
    | SqlConnected _ -> true
    | KvConnected _ -> true
    | Reconnecting _ -> true
    | ConnectionError _ -> true
    | _ -> false
    end

let rec c18_finish_kv (s: t_C18ConnState) (path: t_String) (return (x: t_C18ConnState)) =
  {[@stop_split] [@expl:c18_finish_kv requires] ([@stop_split] [@expl:c18_finish_kv 's' type invariant] [%#slevel18'21] inv_C18ConnState s)
  /\ ([@stop_split] [@expl:c18_finish_kv 'path' type invariant] [%#slevel18'22] inv_String path)
  /\ ([@stop_split] [@expl:c18_finish_kv requires #0] [%#slevel18'23] c18_consistent s)
  /\ ([@stop_split] [@expl:c18_finish_kv requires #1] [%#slevel18'24] c18_backend_is_kv s)
  /\ ([@stop_split] [@expl:c18_finish_kv requires #2] [%#slevel18'25] Seq.length (view_String path) > 0)}
  any
  [ return (result: t_C18ConnState) ->
  {[@stop_split] [@expl:c18_finish_kv ensures] ([@stop_split] [@expl:c18_finish_kv result type invariant] [%#slevel18'26] inv_C18ConnState result)
    /\ ([@stop_split] [@expl:c18_finish_kv ensures #0] [%#slevel18'27] c18_consistent result)
    /\ ([@stop_split] [@expl:c18_finish_kv ensures #1] [%#slevel18'28] c18_is_disconnectable result)}
    (! return {result}) ]

let rec c18_disconnect (s: t_C18ConnState) (return (x: t_C18ConnState)) =
  {[@stop_split] [@expl:c18_disconnect requires] ([@stop_split] [@expl:c18_disconnect 's' type invariant] [%#slevel18'29] inv_C18ConnState s)
  /\ ([@stop_split] [@expl:c18_disconnect requires #0] [%#slevel18'30] c18_consistent s)
  /\ ([@stop_split] [@expl:c18_disconnect requires #1] [%#slevel18'31] c18_is_disconnectable s)}
  any
  [ return (result: t_C18ConnState) ->
  {[@stop_split] [@expl:c18_disconnect ensures] ([@stop_split] [@expl:c18_disconnect result type invariant] [%#slevel18'32] inv_C18ConnState result)
    /\ ([@stop_split] [@expl:c18_disconnect ensures #0] [%#slevel18'33] c18_consistent result)
    /\ ([@stop_split] [@expl:c18_disconnect ensures #1] [%#slevel18'34] c18_is_disconnected result)}
    (! return {result}) ]

meta "compute_max_steps" 1000000

meta "select_lsinst" "all"

let rec c18_lifecycle_kv
  [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level18.rs" 338 0 338 75]
  (profile_name: t_String) (path: t_String) (return (x: t_C18ConnState)) =
  {[@stop_split] [@expl:c18_lifecycle_kv requires] ([@stop_split] [@expl:c18_lifecycle_kv 'profile_name' type invariant] [%#slevel18'3] inv_String profile_name)
  /\ ([@stop_split] [@expl:c18_lifecycle_kv 'path' type invariant] [%#slevel18'4] inv_String path)
  /\ ([@stop_split] [@expl:c18_lifecycle_kv requires #0] [%#slevel18'5] Seq.length (view_String profile_name) > 0)
  /\ ([@stop_split] [@expl:c18_lifecycle_kv requires #1] [%#slevel18'6] Seq.length (view_String path) > 0)}
  (! bb0
  [ bb0 = s0'0
    [ s0'0 = c18_new [%#slevel18] (fun (_x: t_C18ConnState) -> [ &s0 <- _x ] s1'0)
    | s1'0 = c18_begin_kv [%#slevel18'0] {s0} {profile_name} (fun (_x: t_C18ConnState) -> [ &s1 <- _x ] s2'0)
    | s2'0 = c18_finish_kv [%#slevel18'1] {s1} {path} (fun (_x: t_C18ConnState) -> [ &s2 <- _x ] s3)
    | s3 = c18_disconnect [%#slevel18'2] {s2} (fun (_x: t_C18ConnState) -> [ &_ret <- _x ] s4)
    | s4 = return {_ret} ] ]
  [ & _ret: t_C18ConnState = Any.any_l ()
  | & profile_name: t_String = profile_name
  | & path: t_String = path
  | & s0: t_C18ConnState = Any.any_l ()
  | & s1: t_C18ConnState = Any.any_l ()
  | & s2: t_C18ConnState = Any.any_l () ])
  [ return (result: t_C18ConnState) ->
  {[@stop_split] [@expl:c18_lifecycle_kv ensures] ([@stop_split] [@expl:c18_lifecycle_kv result type invariant] [%#slevel18'7] inv_C18ConnState result)
    /\ ([@stop_split] [@expl:c18_lifecycle_kv ensures #0] [%#slevel18'8] c18_consistent result)
    /\ ([@stop_split] [@expl:c18_lifecycle_kv ensures #1] [%#slevel18'9] c18_is_disconnected result)}
    (! return {result}) ]
