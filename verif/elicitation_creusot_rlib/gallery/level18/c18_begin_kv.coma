  (s: t_C18ConnState) (profile_name: t_String) (return (x: t_C18ConnState)) =
  {[@stop_split] [@expl:c18_begin_kv requires] ([@stop_split] [@expl:c18_begin_kv 's' type invariant] [%#slevel18] inv_C18ConnState s)
