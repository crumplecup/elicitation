  /\ ([@stop_split] [@expl:c18_begin_kv requires #0] [%#slevel18'1] c18_is_disconnected s)
  /\ ([@stop_split] [@expl:c18_begin_kv requires #1] [%#slevel18'2] Seq.length (view_String profile_name) > 0)}
  (! bb0
  [ bb0 = s0
    [ s0 = s1 [ _ck -> (! {[@expl:type invariant] inv_C18ConnState s} any) ]
    | s1 = -{resolve_C18ConnState s}- s2
