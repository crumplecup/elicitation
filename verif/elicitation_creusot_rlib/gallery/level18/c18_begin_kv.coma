  [ return (result: t_C18ConnState) ->
  {[@stop_split] [@expl:c18_begin_kv ensures] ([@stop_split] [@expl:c18_begin_kv result type invariant] [%#slevel18'3] inv_C18ConnState result)
    /\ ([@stop_split] [@expl:c18_begin_kv ensures #0] [%#slevel18'4] c18_consistent result)
