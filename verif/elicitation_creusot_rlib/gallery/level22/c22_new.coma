type t_String

type t_C22Profile = { name: t_String; port: Int32.t }

type t_C22State = Idle | Editing t_C22Profile

predicate inv_String (_1: t_String)

predicate inv_C22Profile (_1: t_C22Profile)

axiom inv_axiom [@rewrite]: forall x: t_C22Profile [inv_C22Profile x]. inv_C22Profile x = inv_String x.name

predicate invariant_Box_C22Profile_Global (self: t_C22Profile) = [%#sboxed] inv_C22Profile self

predicate inv_Box_C22Profile_Global [@inline:trivial] (_1: t_C22Profile) = invariant_Box_C22Profile_Global _1

