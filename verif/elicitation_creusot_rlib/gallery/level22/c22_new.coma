predicate inv_C22State (_1: t_C22State)

axiom inv_axiom'0 [@rewrite]: forall x: t_C22State [inv_C22State x]. inv_C22State x
    = match x with
      | Idle -> true
      | Editing profile -> inv_Box_C22Profile_Global profile
      end

function view_String (self: t_String) : Seq.seq Char.t

predicate c22_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level22.rs" 59 0 59 43] (s: t_C22State) =
  [%#slevel22'2] match s with
    | Idle -> true
    | Editing profile -> Seq.length (view_String profile.name) > 0 /\ Int32.to_int profile.port > 0
    end

predicate c22_is_idle [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level22.rs" 71 0 71 40] (s: t_C22State) =
  [%#slevel22'3] match s with
