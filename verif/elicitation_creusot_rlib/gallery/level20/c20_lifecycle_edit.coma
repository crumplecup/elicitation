    /\ ([@stop_split] [@expl:c20_open_browse ensures #0] [%#slevel20'18] c20_consistent result)
    /\ ([@stop_split] [@expl:c20_open_browse ensures #1] [%#slevel20'19] c20_is_browsing result)}
