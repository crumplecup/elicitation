  [ & _ret: t_C20State = Any.any_l ()
  | & data: t_String = data
  | & tag'0: t_String = tag'0
  | & s0: t_C20State = Any.any_l ()
  | & s1: t_C20State = Any.any_l ()
  | & s2: t_C20State = Any.any_l () ])
  [ return (result: t_C20State) ->
  {[@stop_split] [@expl:c20_lifecycle_edit ensures] ([@stop_split] [@expl:c20_lifecycle_edit result type invariant] [%#slevel20'7] inv_C20State result)
