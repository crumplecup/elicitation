use seq.Seq
use creusot.prelude.Char
use creusot.prelude.Any
use int.Int

type t_String

type t_Option_String = None | Some t_String

type t_C20EditState = { tag: t_String }

type t_Option_C20EditState = None'0 | Some'0 t_C20EditState

type t_C20State = Idle | Editing t_String bool t_Option_String t_Option_String | Browsing t_String t_Option_C20EditState

predicate inv_String (_1: t_String)

predicate inv_Option_String (_1: t_Option_String)

axiom inv_axiom [@rewrite]: forall x: t_Option_String [inv_Option_String x]. inv_Option_String x
    = match x with
      | None -> true
      | Some f0 -> inv_String f0
      end

predicate inv_C20EditState (_1: t_C20EditState)

axiom inv_axiom'0 [@rewrite]: forall x: t_C20EditState [inv_C20EditState x]. inv_C20EditState x = inv_String x.tag

predicate inv_Option_C20EditState (_1: t_Option_C20EditState)

axiom inv_axiom'1 [@rewrite]: forall x: t_Option_C20EditState [inv_Option_C20EditState x]. inv_Option_C20EditState x
    = match x with
      | None'0 -> true
      | Some'0 f0 -> inv_C20EditState f0
      end

predicate inv_C20State (_1: t_C20State)

axiom inv_axiom'2 [@rewrite]: forall x: t_C20State [inv_C20State x]. inv_C20State x
    = match x with
      | Idle -> true
      | Editing query running result error -> inv_String query /\ inv_Option_String result /\ inv_Option_String error
      | Browsing data edit_state -> inv_String data /\ inv_Option_C20EditState edit_state
      end

function view_String (self: t_String) : Seq.seq Char.t

predicate c20_edit_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level20.rs" 76 0 76 52] (e: t_C20EditState) =
  [%#slevel20'38] Seq.length (view_String e.tag) > 0

predicate c20_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level20.rs" 121 0 121 43] (s: t_C20State) =
  [%#slevel20'34] match s with
    | Idle -> true
    | Editing query running result error -> Seq.length (view_String query) > 0
    /\ (running
      -> match result with
        | None -> true
        | Some _ -> false
        end)
    /\ (running
      -> match error with
        | None -> true
        | Some _ -> false
        end)
    /\ match result with
        | Some r -> Seq.length (view_String r) > 0
        | None -> true
        end
    /\ match error with
      | Some e -> Seq.length (view_String e) > 0
      | None -> true
      end
    | Browsing data edit_state -> Seq.length (view_String data) > 0
    /\ match edit_state with
      | Some'0 es -> c20_edit_consistent es
      | None'0 -> true
      end
    end

predicate c20_is_idle [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level20.rs" 150 0 150 40] (s: t_C20State) =
  [%#slevel20'35] match s with
    | Idle -> true
    | _ -> false
    end

let rec c20_new (return (x: t_C20State)) = any
  [ return (result: t_C20State) ->
  {[@stop_split] [@expl:c20_new ensures] ([@stop_split] [@expl:c20_new result type invariant] [%#slevel20'10] inv_C20State result)
    /\ ([@stop_split] [@expl:c20_new ensures #0] [%#slevel20'11] c20_consistent result)
    /\ ([@stop_split] [@expl:c20_new ensures #1] [%#slevel20'12] c20_is_idle result)}
    (! return {result}) ]

predicate c20_is_running [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level20.rs" 140 0 140 43] (s: t_C20State) =
  [%#slevel20'36] match s with
    | Editing _ running _ _ -> running
    | _ -> false
    end

let rec c20_start_query (s: t_C20State) (query: t_String) (return (x: t_C20State)) =
  {[@stop_split] [@expl:c20_start_query requires] ([@stop_split] [@expl:c20_start_query 's' type invariant] [%#slevel20'13] inv_C20State s)
  /\ ([@stop_split] [@expl:c20_start_query 'query' type invariant] [%#slevel20'14] inv_String query)
  /\ ([@stop_split] [@expl:c20_start_query requires #0] [%#slevel20'15] c20_consistent s)
  /\ ([@stop_split] [@expl:c20_start_query requires #1] [%#slevel20'16] c20_is_idle s)
  /\ ([@stop_split] [@expl:c20_start_query requires #2] [%#slevel20'17] Seq.length (view_String query) > 0)}
  any
  [ return (result: t_C20State) ->
  {[@stop_split] [@expl:c20_start_query ensures] ([@stop_split] [@expl:c20_start_query result type invariant] [%#slevel20'18] inv_C20State result)
    /\ ([@stop_split] [@expl:c20_start_query ensures #0] [%#slevel20'19] c20_consistent result)
    /\ ([@stop_split] [@expl:c20_start_query ensures #1] [%#slevel20'20] c20_is_running result)}
    (! return {result}) ]

predicate c20_edit_done [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level20.rs" 161 0 161 42] (s: t_C20State) =
  [%#slevel20'37] match s with
    | Editing _ running _ _ -> not running
    | _ -> false
    end

let rec c20_fail (s: t_C20State) (error_msg: t_String) (return (x: t_C20State)) =
  {[@stop_split] [@expl:c20_fail requires] ([@stop_split] [@expl:c20_fail 's' type invariant] [%#slevel20'21] inv_C20State s)
  /\ ([@stop_split] [@expl:c20_fail 'error_msg' type invariant] [%#slevel20'22] inv_String error_msg)
  /\ ([@stop_split] [@expl:c20_fail requires #0] [%#slevel20'23] c20_consistent s)
  /\ ([@stop_split] [@expl:c20_fail requires #1] [%#slevel20'24] c20_is_running s)
  /\ ([@stop_split] [@expl:c20_fail requires #2] [%#slevel20'25] Seq.length (view_String error_msg) > 0)}
  any
  [ return (result: t_C20State) ->
  {[@stop_split] [@expl:c20_fail ensures] ([@stop_split] [@expl:c20_fail result type invariant] [%#slevel20'26] inv_C20State result)
    /\ ([@stop_split] [@expl:c20_fail ensures #0] [%#slevel20'27] c20_consistent result)
    /\ ([@stop_split] [@expl:c20_fail ensures #1] [%#slevel20'28] c20_edit_done result)}
    (! return {result}) ]

let rec c20_reset (s: t_C20State) (return (x: t_C20State)) =
  {[@stop_split] [@expl:c20_reset requires] ([@stop_split] [@expl:c20_reset 's' type invariant] [%#slevel20'29] inv_C20State s)
  /\ ([@stop_split] [@expl:c20_reset requires] [%#slevel20'30] c20_consistent s)}
  any
  [ return (result: t_C20State) ->
  {[@stop_split] [@expl:c20_reset ensures] ([@stop_split] [@expl:c20_reset result type invariant] [%#slevel20'31] inv_C20State result)
    /\ ([@stop_split] [@expl:c20_reset ensures #0] [%#slevel20'32] c20_consistent result)
    /\ ([@stop_split] [@expl:c20_reset ensures #1] [%#slevel20'33] c20_is_idle result)}
    (! return {result}) ]

meta "compute_max_steps" 1000000

meta "select_lsinst" "all"

let rec c20_lifecycle_failure
  [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level20.rs" 322 0 322 74] (query: t_String)
  (error_msg: t_String) (return (x: t_C20State)) =
  {[@stop_split] [@expl:c20_lifecycle_failure requires] ([@stop_split] [@expl:c20_lifecycle_failure 'query' type invariant] [%#slevel20'3] inv_String query)
  /\ ([@stop_split] [@expl:c20_lifecycle_failure 'error_msg' type invariant] [%#slevel20'4] inv_String error_msg)
  /\ ([@stop_split] [@expl:c20_lifecycle_failure requires #0] [%#slevel20'5] Seq.length (view_String query) > 0)
  /\ ([@stop_split] [@expl:c20_lifecycle_failure requires #1] [%#slevel20'6] Seq.length (view_String error_msg) > 0)}
  (! bb0
  [ bb0 = s0'0
    [ s0'0 = c20_new [%#slevel20] (fun (_x: t_C20State) -> [ &s0 <- _x ] s1'0)
    | s1'0 = c20_start_query [%#slevel20'0] {s0} {query} (fun (_x: t_C20State) -> [ &s1 <- _x ] s2'0)
    | s2'0 = c20_fail [%#slevel20'1] {s1} {error_msg} (fun (_x: t_C20State) -> [ &s2 <- _x ] s3)
    | s3 = c20_reset [%#slevel20'2] {s2} (fun (_x: t_C20State) -> [ &_ret <- _x ] s4)
    | s4 = return {_ret} ] ]
  [ & _ret: t_C20State = Any.any_l ()
  | & query: t_String = query
  | & error_msg: t_String = error_msg
  | & s0: t_C20State = Any.any_l ()
  | & s1: t_C20State = Any.any_l ()
  | & s2: t_C20State = Any.any_l () ])
  [ return (result: t_C20State) ->
  {[@stop_split] [@expl:c20_lifecycle_failure ensures] ([@stop_split] [@expl:c20_lifecycle_failure result type invariant] [%#slevel20'7] inv_C20State result)
    /\ ([@stop_split] [@expl:c20_lifecycle_failure ensures #0] [%#slevel20'8] c20_consistent result)
    /\ ([@stop_split] [@expl:c20_lifecycle_failure ensures #1] [%#slevel20'9] c20_is_idle result)}
