use creusot.int.Int64
use creusot.prelude.Any
use seq.Seq
use creusot.prelude.Char
use int.Int

type t_String

type t_MiniConnState = Disconnected | Connecting t_String | Connected t_String | Error t_String

type t_C13Machine = { state: t_MiniConnState; transition_count: Int64.t }

let rec elim_Connecting (_x: t_MiniConnState) (return (name: t_String)) = any
  [ _k (name: t_String) -> {Connecting name = _x} (! return {name})
  | _chk -> (! {[@expl:elim Connecting] match _x with
      | Connecting _ -> true
      | _ -> false
      end}
    any) ]

predicate inv_String (_1: t_String)

predicate inv_MiniConnState (_1: t_MiniConnState)

axiom inv_axiom [@rewrite]: forall x: t_MiniConnState [inv_MiniConnState x]. inv_MiniConnState x
    = match x with
      | Disconnected -> true
      | Connecting name -> inv_String name
      | Connected name -> inv_String name
      | Error message -> inv_String message
      end

predicate inv_C13Machine (_1: t_C13Machine)

axiom inv_axiom'0 [@rewrite]: forall x: t_C13Machine [inv_C13Machine x]. inv_C13Machine x = inv_MiniConnState x.state

function view_String (self: t_String) : Seq.seq Char.t

predicate c13_state_ok [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level13.rs" 69 0 69 46] (s: t_MiniConnState) =
  [%#slevel13'15] match s with
    | Disconnected -> true
    | Connecting name -> Seq.length (view_String name) > 0
    | Connected name -> Seq.length (view_String name) > 0
    | Error message -> Seq.length (view_String message) > 0
    end

predicate c13_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level13.rs" 94 0 94 45] (m: t_C13Machine) =
  [%#slevel13'11] c13_state_ok m.state /\ Int64.to_int m.transition_count >= 0

predicate c13_is_connecting [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level13.rs" 121 0 121 48] (m: t_C13Machine) =
  [%#slevel13'12] match m.state with
    | Connecting _ -> true
    | _ -> false
    end

constant const_MAX: Int64.t = (9223372036854775807: Int64.t)

predicate c13_below_max [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level13.rs" 102 0 102 44] (m: t_C13Machine) =
  [%#slevel13'13] Int64.to_int m.transition_count < Int64.to_int const_MAX

predicate c13_is_connected [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level13.rs" 132 0 132 47] (m: t_C13Machine) =
  [%#slevel13'14] match m.state with
    | Connected _ -> true
    | _ -> false
    end

meta "compute_max_steps" 1000000

meta "select_lsinst" "all"

let rec c13_succeed [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level13.rs" 182 0 182 47]
  (m: t_C13Machine) (return (x: t_C13Machine)) =
  {[@stop_split] [@expl:c13_succeed requires] ([@stop_split] [@expl:c13_succeed 'm' type invariant] [%#slevel13'3] inv_C13Machine m)
  /\ ([@stop_split] [@expl:c13_succeed requires #0] [%#slevel13'4] c13_consistent m)
  /\ ([@stop_split] [@expl:c13_succeed requires #1] [%#slevel13'5] c13_is_connecting m)
  /\ ([@stop_split] [@expl:c13_succeed requires #2] [%#slevel13'6] c13_below_max m)}
  (! bb0
  [ bb0 = any
    [ br0 -> {m.state = Disconnected} (! bb1)
    | br1 (x0: t_String) -> {m.state = Connecting x0} (! bb3)
    | br2 (x0: t_String) -> {m.state = Connected x0} (! bb1)
    | br3 (x0: t_String) -> {m.state = Error x0} (! bb1) ]
  | bb1 = s0
    [ s0 = [ &other <- m.state ] s1
    | s1 = Int64.add [%#slevel13'0] {m.transition_count} {[%#slevel13] (1: Int64.t)}
        (fun (_x: Int64.t) -> [ &_20 <- _x ] s2)
    | s2 = [ &_ret <- { state = other; transition_count = _20 } ] s3
    | s3 = return {_ret} ]
  | bb3 = s0
    [ s0 = elim_Connecting {m.state} (fun (rname: t_String) -> [ &name <- rname ] s1)
    | s1 = [ &_14 <- Connected name ] s2
    | s2 = Int64.add [%#slevel13'2] {m.transition_count} {[%#slevel13'1] (1: Int64.t)}
        (fun (_x: Int64.t) -> [ &_16 <- _x ] s3)
    | s3 = [ &_ret <- { state = _14; transition_count = _16 } ] s4
    | s4 = return {_ret} ] ]
  [ & _ret: t_C13Machine = Any.any_l ()
  | & m: t_C13Machine = m
  | & name: t_String = Any.any_l ()
  | & _14: t_MiniConnState = Any.any_l ()
  | & _16: Int64.t = Any.any_l ()
  | & other: t_MiniConnState = Any.any_l ()
  | & _20: Int64.t = Any.any_l () ])
  [ return (result: t_C13Machine) ->
  {[@stop_split] [@expl:c13_succeed ensures] ([@stop_split] [@expl:c13_succeed result type invariant] [%#slevel13'7] inv_C13Machine result)
    /\ ([@stop_split] [@expl:c13_succeed ensures #0] [%#slevel13'8] c13_consistent result)
    /\ ([@stop_split] [@expl:c13_succeed ensures #1] [%#slevel13'9] c13_is_connected result)
    /\ ([@stop_split] [@expl:c13_succeed ensures #2] [%#slevel13'10] Int64.to_int result.transition_count
    = Int64.to_int m.transition_count + 1)}
    (! return {result}) ]
