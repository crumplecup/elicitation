    | s1 = [ &_ret <- { state = _5;
                        transition_count = ([%#slevel14] (0: Int64.t));
                        error_count = ([%#slevel14'0] (0: Int64.t)) } ] s2
    | s2 = return {_ret} ] ] [ & _ret: t_C14Machine = Any.any_l () | & _5: t_MiniConnState = Any.any_l () ])
  [ return (result: t_C14Machine) ->
  {[@stop_split] [@expl:c14_new ensures] ([@stop_split] [@expl:c14_new result type invariant] [%#slevel14'1] inv_C14Machine result)
    /\ ([@stop_split] [@expl:c14_new ensures #0] [%#slevel14'2] c14_consistent result)
