use creusot.int.Int64
use creusot.prelude.Any
use seq.Seq
use creusot.prelude.Char
use int.Int

type t_String

type t_MiniConnState = Disconnected | Connecting t_String | Connected t_String | Error t_String

type t_C14Machine = { state: t_MiniConnState; transition_count: Int64.t; error_count: Int64.t }

let rec elim_Connecting (_x: t_MiniConnState) (return (name: t_String)) = any
  [ _k (name: t_String) -> {Connecting name = _x} (! return {name})
  | _chk -> (! {[@expl:elim Connecting] match _x with
      | Connecting _ -> true
      | _ -> false
      end}
    any) ]

predicate inv_String (_1: t_String)

predicate inv_MiniConnState (_1: t_MiniConnState)

axiom inv_axiom [@rewrite]: forall x: t_MiniConnState [inv_MiniConnState x]. inv_MiniConnState x
    = match x with
      | Disconnected -> true
      | Connecting name -> inv_String name
      | Connected name -> inv_String name
      | Error message -> inv_String message
      end

predicate inv_C14Machine (_1: t_C14Machine)

axiom inv_axiom'0 [@rewrite]: forall x: t_C14Machine [inv_C14Machine x]. inv_C14Machine x = inv_MiniConnState x.state

function view_String (self: t_String) : Seq.seq Char.t

predicate c14_state_ok [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level14.rs" 55 0 55 46] (s: t_MiniConnState) =
  [%#slevel14'16] match s with
    | Disconnected -> true
    | Connecting name -> Seq.length (view_String name) > 0
    | Connected name -> Seq.length (view_String name) > 0
    | Error message -> Seq.length (view_String message) > 0
    end

predicate c14_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level14.rs" 80 0 80 45] (m: t_C14Machine) =
  [%#slevel14'12] c14_state_ok m.state
  /\ Int64.to_int m.transition_count >= 0
  /\ Int64.to_int m.error_count >= 0 /\ Int64.to_int m.error_count <= Int64.to_int m.transition_count

predicate c14_is_connecting [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level14.rs" 116 0 116 48] (m: t_C14Machine) =
  [%#slevel14'13] match m.state with
    | Connecting _ -> true
    | _ -> false
    end

constant const_MAX: Int64.t = (9223372036854775807: Int64.t)

predicate c14_below_max [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level14.rs" 91 0 91 44] (m: t_C14Machine) =
  [%#slevel14'14] Int64.to_int m.transition_count < Int64.to_int const_MAX

predicate c14_is_connected [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level14.rs" 127 0 127 47] (m: t_C14Machine) =
  [%#slevel14'15] match m.state with
    | Connected _ -> true
    | _ -> false
    end

meta "compute_max_steps" 1000000

meta "select_lsinst" "all"

let rec c14_succeed [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level14.rs" 179 0 179 47]
  (m: t_C14Machine) (return (x: t_C14Machine)) =
  {[@stop_split] [@expl:c14_succeed requires] ([@stop_split] [@expl:c14_succeed 'm' type invariant] [%#slevel14'3] inv_C14Machine m)
  /\ ([@stop_split] [@expl:c14_succeed requires #0] [%#slevel14'4] c14_consistent m)
  /\ ([@stop_split] [@expl:c14_succeed requires #1] [%#slevel14'5] c14_is_connecting m)
  /\ ([@stop_split] [@expl:c14_succeed requires #2] [%#slevel14'6] c14_below_max m)}
  (! bb0
  [ bb0 = any
    [ br0 -> {m.state = Disconnected} (! bb1)
    | br1 (x0: t_String) -> {m.state = Connecting x0} (! bb3)
    | br2 (x0: t_String) -> {m.state = Connected x0} (! bb1)
    | br3 (x0: t_String) -> {m.state = Error x0} (! bb1) ]
  | bb1 = s0
    [ s0 = [ &other <- m.state ] s1
    | s1 = Int64.add [%#slevel14'0] {m.transition_count} {[%#slevel14] (1: Int64.t)}
        (fun (_x: Int64.t) -> [ &_23 <- _x ] s2)
    | s2 = [ &_ret <- { state = other; transition_count = _23; error_count = m.error_count } ] s3
    | s3 = return {_ret} ]
  | bb3 = s0
    [ s0 = elim_Connecting {m.state} (fun (rname: t_String) -> [ &name <- rname ] s1)
    | s1 = [ &_16 <- Connected name ] s2
    | s2 = Int64.add [%#slevel14'2] {m.transition_count} {[%#slevel14'1] (1: Int64.t)}
        (fun (_x: Int64.t) -> [ &_18 <- _x ] s3)
    | s3 = [ &_ret <- { state = _16; transition_count = _18; error_count = m.error_count } ] s4
    | s4 = return {_ret} ] ]
  [ & _ret: t_C14Machine = Any.any_l ()
  | & m: t_C14Machine = m
  | & name: t_String = Any.any_l ()
  | & _16: t_MiniConnState = Any.any_l ()
  | & _18: Int64.t = Any.any_l ()
  | & other: t_MiniConnState = Any.any_l ()
  | & _23: Int64.t = Any.any_l () ])
  [ return (result: t_C14Machine) ->
  {[@stop_split] [@expl:c14_succeed ensures] ([@stop_split] [@expl:c14_succeed result type invariant] [%#slevel14'7] inv_C14Machine result)
    /\ ([@stop_split] [@expl:c14_succeed ensures #0] [%#slevel14'8] c14_consistent result)
    /\ ([@stop_split] [@expl:c14_succeed ensures #1] [%#slevel14'9] c14_is_connected result)
    /\ ([@stop_split] [@expl:c14_succeed ensures #2] [%#slevel14'10] Int64.to_int result.transition_count
      = Int64.to_int m.transition_count + 1)
    /\ ([@stop_split] [@expl:c14_succeed ensures #3] [%#slevel14'11] Int64.to_int result.error_count
    = Int64.to_int m.error_count)}
    (! return {result}) ]
