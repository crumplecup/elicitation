use creusot.int.Int64
use seq.Seq
use creusot.prelude.Char
use creusot.prelude.Any
use int.Int

type t_String

type t_MiniConnState = Disconnected | Connecting t_String | Connected t_String | Error t_String

type t_C14Machine = { state: t_MiniConnState; transition_count: Int64.t; error_count: Int64.t }

predicate inv_String (_1: t_String)

predicate inv_MiniConnState (_1: t_MiniConnState)

axiom inv_axiom [@rewrite]: forall x: t_MiniConnState [inv_MiniConnState x]. inv_MiniConnState x
    = match x with
      | Disconnected -> true
      | Connecting name -> inv_String name
      | Connected name -> inv_String name
      | Error message -> inv_String message
      end

predicate inv_C14Machine (_1: t_C14Machine)

axiom inv_axiom'0 [@rewrite]: forall x: t_C14Machine [inv_C14Machine x]. inv_C14Machine x = inv_MiniConnState x.state

function view_String (self: t_String) : Seq.seq Char.t

predicate c14_state_ok [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level14.rs" 55 0 55 46] (s: t_MiniConnState) =
  [%#slevel14'65] match s with
    | Disconnected -> true
    | Connecting name -> Seq.length (view_String name) > 0
    | Connected name -> Seq.length (view_String name) > 0
    | Error message -> Seq.length (view_String message) > 0
    end

predicate c14_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level14.rs" 80 0 80 45] (m: t_C14Machine) =
  [%#slevel14'59] c14_state_ok m.state
  /\ Int64.to_int m.transition_count >= 0
  /\ Int64.to_int m.error_count >= 0 /\ Int64.to_int m.error_count <= Int64.to_int m.transition_count

predicate c14_is_disconnected [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level14.rs" 105 0 105 50] (m: t_C14Machine) =
  [%#slevel14'60] match m.state with
    | Disconnected -> true
    | _ -> false
    end

let rec c14_new (return (x: t_C14Machine)) = any
  [ return (result: t_C14Machine) ->
  {[@stop_split] [@expl:c14_new ensures] ([@stop_split] [@expl:c14_new result type invariant] [%#slevel14'17] inv_C14Machine result)
    /\ ([@stop_split] [@expl:c14_new ensures #0] [%#slevel14'18] c14_consistent result)
    /\ ([@stop_split] [@expl:c14_new ensures #1] [%#slevel14'19] c14_is_disconnected result)
    /\ ([@stop_split] [@expl:c14_new ensures #2] [%#slevel14'20] Int64.to_int result.transition_count = 0)
    /\ ([@stop_split] [@expl:c14_new ensures #3] [%#slevel14'21] Int64.to_int result.error_count = 0)}
    (! return {result}) ]

constant const_MAX: Int64.t = (9223372036854775807: Int64.t)

predicate c14_below_max [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level14.rs" 91 0 91 44] (m: t_C14Machine) =
  [%#slevel14'61] Int64.to_int m.transition_count < Int64.to_int const_MAX

predicate c14_is_connecting [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level14.rs" 116 0 116 48] (m: t_C14Machine) =
  [%#slevel14'62] match m.state with
    | Connecting _ -> true
    | _ -> false
    end

let rec c14_begin (m: t_C14Machine) (name: t_String) (return (x: t_C14Machine)) =
  {[@stop_split] [@expl:c14_begin requires] ([@stop_split] [@expl:c14_begin 'm' type invariant] [%#slevel14'22] inv_C14Machine m)
  /\ ([@stop_split] [@expl:c14_begin 'name' type invariant] [%#slevel14'23] inv_String name)
  /\ ([@stop_split] [@expl:c14_begin requires #0] [%#slevel14'24] c14_consistent m)
  /\ ([@stop_split] [@expl:c14_begin requires #1] [%#slevel14'25] c14_below_max m)
  /\ ([@stop_split] [@expl:c14_begin requires #2] [%#slevel14'26] Seq.length (view_String name) > 0)}
  any
  [ return (result: t_C14Machine) ->
  {[@stop_split] [@expl:c14_begin ensures] ([@stop_split] [@expl:c14_begin result type invariant] [%#slevel14'27] inv_C14Machine result)
    /\ ([@stop_split] [@expl:c14_begin ensures #0] [%#slevel14'28] c14_consistent result)
    /\ ([@stop_split] [@expl:c14_begin ensures #1] [%#slevel14'29] c14_is_connecting result)
    /\ ([@stop_split] [@expl:c14_begin ensures #2] [%#slevel14'30] Int64.to_int result.transition_count
      = Int64.to_int m.transition_count + 1)
    /\ ([@stop_split] [@expl:c14_begin ensures #3] [%#slevel14'31] Int64.to_int result.error_count
    = Int64.to_int m.error_count)}
    (! return {result}) ]

predicate c14_errors_below_max [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level14.rs" 97 0 97 51] (m: t_C14Machine) =
  [%#slevel14'63] Int64.to_int m.error_count < Int64.to_int const_MAX

