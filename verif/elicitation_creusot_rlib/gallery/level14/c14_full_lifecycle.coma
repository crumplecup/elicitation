let rec c14_full_lifecycle
  [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level14.rs" 254 0 254 85] (name: t_String)
  (name2: t_String) (message: t_String) (return (x: t_C14Machine)) =
  {[@stop_split] [@expl:c14_full_lifecycle requires] ([@stop_split] [@expl:c14_full_lifecycle 'name' type invariant] [%#slevel14'6] inv_String name)
  /\ ([@stop_split] [@expl:c14_full_lifecycle 'name2' type invariant] [%#slevel14'7] inv_String name2)
  /\ ([@stop_split] [@expl:c14_full_lifecycle 'message' type invariant] [%#slevel14'8] inv_String message)
  /\ ([@stop_split] [@expl:c14_full_lifecycle requires #0] [%#slevel14'9] Seq.length (view_String name) > 0)
  /\ ([@stop_split] [@expl:c14_full_lifecycle requires #1] [%#slevel14'10] Seq.length (view_String name2) > 0)
  /\ ([@stop_split] [@expl:c14_full_lifecycle requires #2] [%#slevel14'11] Seq.length (view_String message) > 0)}
  (! bb0
  [ bb0 = s0
    [ s0 = c14_new [%#slevel14] (fun (_x: t_C14Machine) -> [ &m0 <- _x ] s1)
    | s1 = c14_begin [%#slevel14'0] {m0} {name} (fun (_x: t_C14Machine) -> [ &m1 <- _x ] s2)
    | s2 = c14_fail [%#slevel14'1] {m1} {message} (fun (_x: t_C14Machine) -> [ &m2 <- _x ] s3)
    | s3 = c14_disconnect [%#slevel14'2] {m2} (fun (_x: t_C14Machine) -> [ &m3 <- _x ] s4)
    | s4 = c14_begin [%#slevel14'3] {m3} {name2} (fun (_x: t_C14Machine) -> [ &m4 <- _x ] s5)
    | s5 = c14_succeed [%#slevel14'4] {m4} (fun (_x: t_C14Machine) -> [ &m5 <- _x ] s6)
    | s6 = c14_disconnect [%#slevel14'5] {m5} (fun (_x: t_C14Machine) -> [ &_ret <- _x ] s7)
    | s7 = return {_ret} ] ]
  [ & _ret: t_C14Machine = Any.any_l ()
  | & name: t_String = name
  | & name2: t_String = name2
  | & message: t_String = message
  | & m0: t_C14Machine = Any.any_l ()
  | & m1: t_C14Machine = Any.any_l ()
  | & m2: t_C14Machine = Any.any_l ()
  | & m3: t_C14Machine = Any.any_l ()
  | & m4: t_C14Machine = Any.any_l ()
  | & m5: t_C14Machine = Any.any_l () ])
  [ return (result: t_C14Machine) ->
  {[@stop_split] [@expl:c14_full_lifecycle ensures] ([@stop_split] [@expl:c14_full_lifecycle result type invariant] [%#slevel14'12] inv_C14Machine result)
    /\ ([@stop_split] [@expl:c14_full_lifecycle ensures #0] [%#slevel14'13] c14_consistent result)
    /\ ([@stop_split] [@expl:c14_full_lifecycle ensures #1] [%#slevel14'14] c14_is_disconnected result)
    /\ ([@stop_split] [@expl:c14_full_lifecycle ensures #2] [%#slevel14'15] Int64.to_int result.transition_count = 6)
    /\ ([@stop_split] [@expl:c14_full_lifecycle ensures #3] [%#slevel14'16] Int64.to_int result.error_count = 1)}
    (! return {result}) ]
