        (fun (_x: Int64.t) -> [ &_18 <- _x ] s2)
    | s2 = s3 [ _ck -> (! {[@expl:type invariant] inv_C14Machine m} any) ]
    | s3 = -{resolve_C14Machine m}- s4
    | s4 = Int64.add [%#slevel14'2] {m.error_count} {[%#slevel14'1] (1: Int64.t)}
        (fun (_x: Int64.t) -> [ &_20 <- _x ] s5)
    | s5 = [ &_ret <- { state = _16; transition_count = _18; error_count = _20 } ] s6
