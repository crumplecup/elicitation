    | s1 = [ &_ret <- { state = _3; transition_count = ([%#slevel8] (0: Int64.t)) } ] s2
    | s2 = return {_ret} ] ] [ & _ret: t_C8Machine = Any.any_l () | & _3: t_C8ConnState = Any.any_l () ])
  [ return (result: t_C8Machine) -> {[@stop_split] [@expl:c8_new ensures] [%#slevel8'1] c8_consistent result}
    (! return {result}) ]
