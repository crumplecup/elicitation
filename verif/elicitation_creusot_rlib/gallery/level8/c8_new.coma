use creusot.int.Int64
use creusot.prelude.Any
use int.Int

type t_C8ConnState = Disconnected | Connected

type t_C8Machine = { state: t_C8ConnState; transition_count: Int64.t }

predicate c8_state_ok [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level8.rs" 37 0 37 43] (s: t_C8ConnState) =
  [%#slevel8'3] match s with
    | Disconnected -> true
    | Connected -> true
    end

predicate c8_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level8.rs" 62 0 62 43] (m: t_C8Machine) =
  [%#slevel8'2] c8_state_ok m.state /\ Int64.to_int m.transition_count >= 0

meta "compute_max_steps" 1000000

meta "select_lsinst" "all"

let rec c8_new [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level8.rs" 83 0 83 28]
