type t_C25State = Idle | Active Int64.t

predicate c25_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level25.rs" 92 0 92 43] (s: t_C25State) =
  [%#slevel25'1] match s with
    | Idle -> true
    | Active value -> Int64.to_int value > 0
    end

meta "compute_max_steps" 1000000

