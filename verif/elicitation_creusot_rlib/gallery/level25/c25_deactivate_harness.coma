use creusot.int.Int64
use creusot.prelude.Any
use int.Int

type t_C25State = Idle | Active Int64.t

predicate c25_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level25.rs" 135 0 135 43] (s: t_C25State) =
  [%#slevel25'4] match s with
    | Idle -> true
    | Active value -> Int64.to_int value > 0
    end

let rec c25_deactivate (state: t_C25State) (return (x: t_C25State)) =
  {[@stop_split] [@expl:c25_deactivate requires] [%#slevel25'2] c25_consistent state}
  any
  [ return (result: t_C25State) -> {[@stop_split] [@expl:c25_deactivate ensures] [%#slevel25'3] c25_consistent result}
    (! return {result}) ]

meta "compute_max_steps" 1000000

