predicate inv_C23State (_1: t_C23State)

axiom inv_axiom'12 [@rewrite]: forall x: t_C23State [inv_C23State x]. inv_C23State x
    = match x with
      | ColumnDetail -> true
      | Loading schema label' -> inv_String schema /\ inv_String label'
      | DataGrid schema table entries grid_row edit_state -> inv_String schema
      /\ inv_String table /\ inv_Vec_String_Global entries /\ inv_Option_C23EditState edit_state
      | SqlEditor text'0 result running error -> inv_String text'0
      /\ inv_Option_String result /\ inv_Option_String error
      | DdlView schema table ddl -> inv_String schema /\ inv_String table /\ inv_String ddl
      | ExplainView schema table plan -> inv_String schema /\ inv_String table /\ inv_String plan
      | ExplainCompare schema table left right -> inv_String schema
      /\ inv_String table /\ inv_String left /\ inv_String right
      | HistoryView entries -> inv_Vec_C23HistoryEntry_Global entries
      | SavedView entries -> inv_Vec_C23SavedQuery_Global entries
      | ExportView schema table result -> inv_String schema /\ inv_String table /\ inv_Option_String result
      | HelpView -> true
      | MonitorView snapshot loading -> inv_String snapshot
      | AdminView snapshot loading -> inv_String snapshot
      | ErdView schema diagram layout loading -> inv_String schema /\ inv_String diagram /\ inv_Option_String layout
      | ConstraintView schema table constraints loading -> inv_String schema
      /\ inv_String table /\ inv_Vec_C23Constraint_Global constraints
      | IndexView schema table indexes loading -> inv_String schema
      /\ inv_String table /\ inv_Vec_C23Index_Global indexes
      | ConnectionEdit profile -> inv_Box_C23Profile_Global profile
      | ErrorView message -> inv_String message
      end

function view_String (self: t_String) : Seq.seq Char.t

predicate c23_consistent [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level23.rs" 194 0 194 43] (s: t_C23State) =
  [%#slevel23'40] match s with
    | ColumnDetail -> true
    | Loading schema label' -> Seq.length (view_String schema) > 0 /\ Seq.length (view_String label') > 0
    | DataGrid schema table entries grid_row _ -> Seq.length (view_String schema) > 0
    /\ Seq.length (view_String table) > 0 /\ UInt64.t'int grid_row <= Seq.length (view_Vec_String_Global entries)
    | SqlEditor _ result running _ -> running
    -> match result with
      | None'0 -> true
      | Some'0 _ -> false
      end
    | DdlView schema table _ -> Seq.length (view_String schema) > 0 /\ Seq.length (view_String table) > 0
    | ExplainView schema table _ -> Seq.length (view_String schema) > 0 /\ Seq.length (view_String table) > 0
    | ExplainCompare schema table _ _ -> Seq.length (view_String schema) > 0 /\ Seq.length (view_String table) > 0
    | HistoryView _ -> true
    | SavedView _ -> true
    | ExportView schema table _ -> Seq.length (view_String schema) > 0 /\ Seq.length (view_String table) > 0
    | HelpView -> true
    | MonitorView _ _ -> true
    | AdminView _ _ -> true
    | ErdView schema _ _ _ -> Seq.length (view_String schema) > 0
    | ConstraintView schema table _ _ -> Seq.length (view_String schema) > 0 /\ Seq.length (view_String table) > 0
    | IndexView schema table _ _ -> Seq.length (view_String schema) > 0 /\ Seq.length (view_String table) > 0
    | ConnectionEdit profile -> Seq.length (view_String profile.name) > 0 /\ Int32.to_int profile.port > 0
    | ErrorView message -> Seq.length (view_String message) > 0
    end

predicate c23_is_column_detail [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level23.rs" 233 0 233 49] (s: t_C23State) =
  [%#slevel23'41] match s with
    | ColumnDetail -> true
    | _ -> false
    end

let rec c23_new (return (x: t_C23State)) = any
  [ return (result: t_C23State) ->
  {[@stop_split] [@expl:c23_new ensures] ([@stop_split] [@expl:c23_new result type invariant] [%#slevel23'14] inv_C23State result)
    /\ ([@stop_split] [@expl:c23_new ensures #0] [%#slevel23'15] c23_consistent result)
    /\ ([@stop_split] [@expl:c23_new ensures #1] [%#slevel23'16] c23_is_column_detail result)}
    (! return {result}) ]

predicate c23_is_loading [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level23.rs" 244 0 244 43] (s: t_C23State) =
  [%#slevel23'25] match s with
    | Loading _ _ -> true
    | _ -> false
    end

let rec c23_start_loading (_s: t_C23State) (schema: t_String) (label': t_String) (return (x: t_C23State)) =
  {[@stop_split] [@expl:c23_start_loading requires] ([@stop_split] [@expl:c23_start_loading '_s' type invariant] [%#slevel23'17] inv_C23State _s)
  /\ ([@stop_split] [@expl:c23_start_loading 'schema' type invariant] [%#slevel23'18] inv_String schema)
  /\ ([@stop_split] [@expl:c23_start_loading 'label' type invariant] [%#slevel23'19] inv_String label')
  /\ ([@stop_split] [@expl:c23_start_loading requires #0] [%#slevel23'20] Seq.length (view_String schema) > 0)
  /\ ([@stop_split] [@expl:c23_start_loading requires #1] [%#slevel23'21] Seq.length (view_String label') > 0)}
  any
  [ return (result: t_C23State) ->
  {[@stop_split] [@expl:c23_start_loading ensures] ([@stop_split] [@expl:c23_start_loading result type invariant] [%#slevel23'22] inv_C23State result)
    /\ ([@stop_split] [@expl:c23_start_loading ensures #0] [%#slevel23'23] c23_consistent result)
    /\ ([@stop_split] [@expl:c23_start_loading ensures #1] [%#slevel23'24] c23_is_loading result)}
    (! return {result}) ]

predicate c23_is_sql_editor [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level23.rs" 266 0 266 46] (s: t_C23State) =
  [%#slevel23'30] match s with
