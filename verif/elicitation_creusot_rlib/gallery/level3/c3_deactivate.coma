predicate c3_is_active [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level3.rs" 36 0 36 39] (s: t_GState) =
  [%#slevel3'1] match s with
    | Active -> true
    | Inactive -> false
    end

meta "compute_max_steps" 1000000

