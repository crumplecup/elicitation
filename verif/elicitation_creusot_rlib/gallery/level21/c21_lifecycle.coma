let rec c21_lifecycle [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/gallery/level21.rs" 184 0 184 54]
  (entries: t_Vec_String_Global) (return (x: t_C21State)) =
  {[@stop_split] [@expl:c21_lifecycle requires] ([@stop_split] [@expl:c21_lifecycle 'entries' type invariant] [%#slevel21'4] inv_Vec_String_Global entries)
  /\ ([@stop_split] [@expl:c21_lifecycle requires #0] [%#slevel21'5] Seq.length (view_Vec_String_Global entries) > 0)
  /\ ([@stop_split] [@expl:c21_lifecycle requires #1] [%#slevel21'6] forall i: int. 0 <= i
      /\ i < Seq.length (view_Vec_String_Global entries)
    -> Seq.length (view_String (Seq.get (view_Vec_String_Global entries) i)) > 0)}
  (! bb0
  [ bb0 = s0'0
    [ s0'0 = c21_new [%#slevel21] (fun (_x: t_C21State) -> [ &s0 <- _x ] s1'0)
    | s1'0 = c21_load [%#slevel21'0] {s0} {entries} (fun (_x: t_C21State) -> [ &s1 <- _x ] s2'0)
    | s2'0 = c21_cursor_down [%#slevel21'1] {s1} (fun (_x: t_C21State) -> [ &s2 <- _x ] s3'0)
    | s3'0 = c21_cursor_up [%#slevel21'2] {s2} (fun (_x: t_C21State) -> [ &s3 <- _x ] s4)
    | s4 = c21_clear [%#slevel21'3] {s3} (fun (_x: t_C21State) -> [ &_ret <- _x ] s5)
    | s5 = return {_ret} ] ]
  [ & _ret: t_C21State = Any.any_l ()
  | & entries: t_Vec_String_Global = entries
  | & s0: t_C21State = Any.any_l ()
  | & s1: t_C21State = Any.any_l ()
  | & s2: t_C21State = Any.any_l ()
  | & s3: t_C21State = Any.any_l () ])
  [ return (result: t_C21State) ->
  {[@stop_split] [@expl:c21_lifecycle ensures] ([@stop_split] [@expl:c21_lifecycle result type invariant] [%#slevel21'7] inv_C21State result)
    /\ ([@stop_split] [@expl:c21_lifecycle ensures #0] [%#slevel21'8] c21_consistent result)
    /\ ([@stop_split] [@expl:c21_lifecycle ensures #1] [%#slevel21'9] c21_is_empty result)}
    (! return {result}) ]
