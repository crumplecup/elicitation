  /\ ([@stop_split] [@expl:c21_load requires #1] [%#slevel21'16] forall i: int. 0 <= i
      /\ i < Seq.length (view_Vec_String_Global entries)
    -> Seq.length (view_String (Seq.get (view_Vec_String_Global entries) i)) > 0)}
  any
  [ return (result: t_C21State) ->
  {[@stop_split] [@expl:c21_load ensures] ([@stop_split] [@expl:c21_load result type invariant] [%#slevel21'17] inv_C21State result)
    /\ ([@stop_split] [@expl:c21_load ensures #0] [%#slevel21'18] c21_consistent result)
    /\ ([@stop_split] [@expl:c21_load ensures #1] [%#slevel21'19] c21_is_loaded result)}
