    /\ ([@stop_split] [@expl:new ensures #2] [%#sextern_specs'2] ipv6_is_unspecified result
    = (index_array_u8_16 octets 0 = (0: UInt8.t)
    /\ index_array_u8_16 octets 1 = (0: UInt8.t)
