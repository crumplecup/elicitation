use creusot.int.UInt16
use creusot.prelude.Any
use int.Int

let rec is_dynamic_port (port: UInt16.t) (return (x: bool)) = any
  [ return (result: bool) -> {[@stop_split] [@expl:is_dynamic_port ensures] [%#sextern_specs] result
    = (UInt16.t'int port >= 49152)}
    (! return {result}) ]

