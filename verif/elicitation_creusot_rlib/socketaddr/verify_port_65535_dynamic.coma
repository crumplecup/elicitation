let rec verify_port_65535_dynamic
  [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/socketaddr.rs" 194 0 194 42] (return (x: bool)) =
  (! bb0
  [ bb0 = s0
    [ s0 = is_dynamic_port [%#ssocketaddr'0] {[%#ssocketaddr] (65535: UInt16.t)} (fun (_x: bool) -> [ &_ret <- _x ] s1)
    | s1 = return {_ret} ] ] [ & _ret: bool = Any.any_l () ])
  [ return (result: bool) -> {[@stop_split] [@expl:verify_port_65535_dynamic ensures] [%#ssocketaddr'1] result}
    (! return {result}) ]
