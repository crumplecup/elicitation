use creusot.int.UInt16
use creusot.prelude.Any

let rec is_nonzero_port (port: UInt16.t) (return (x: bool)) = any
  [ return (result: bool) -> {[@stop_split] [@expl:is_nonzero_port ensures] [%#sextern_specs] result
    = (UInt16.t'int port <> 0)}
