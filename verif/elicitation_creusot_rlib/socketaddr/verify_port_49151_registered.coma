  [ bb0 = s0
    [ s0 = is_registered_port [%#ssocketaddr'0] {[%#ssocketaddr] (49151: UInt16.t)}
        (fun (_x: bool) -> [ &_ret <- _x ] s1)
    | s1 = return {_ret} ] ] [ & _ret: bool = Any.any_l () ])
  [ return (result: bool) -> {[@stop_split] [@expl:verify_port_49151_registered ensures] [%#ssocketaddr'1] result}
