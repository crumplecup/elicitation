use creusot.int.UInt16
use creusot.prelude.Any
use int.Int

let rec is_registered_port (port: UInt16.t) (return (x: bool)) = any
  [ return (result: bool) -> {[@stop_split] [@expl:is_registered_port ensures] [%#sextern_specs] result
    = (1024 <= UInt16.t'int port /\ UInt16.t'int port <= 49151)}
    (! return {result}) ]

