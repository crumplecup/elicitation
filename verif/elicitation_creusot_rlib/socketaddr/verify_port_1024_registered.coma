use creusot.int.UInt16
use creusot.prelude.Any
use int.Int

let rec is_registered_port (port: UInt16.t) (return (x: bool)) = any
  [ return (result: bool) -> {[@stop_split] [@expl:is_registered_port ensures] [%#sextern_specs] result
    = (1024 <= UInt16.t'int port /\ UInt16.t'int port <= 49151)}
    (! return {result}) ]

meta "compute_max_steps" 1000000

meta "select_lsinst" "all"

let rec verify_port_1024_registered
  [#"/home/erik/repos/elicitation/crates/elicitation_creusot/src/socketaddr.rs" 163 0 163 44] (return (x: bool)) =
  (! bb0
  [ bb0 = s0
    [ s0 = is_registered_port [%#ssocketaddr'0] {[%#ssocketaddr] (1024: UInt16.t)}
        (fun (_x: bool) -> [ &_ret <- _x ] s1)
    | s1 = return {_ret} ] ] [ & _ret: bool = Any.any_l () ])
  [ return (result: bool) -> {[@stop_split] [@expl:verify_port_1024_registered ensures] [%#ssocketaddr'1] result}
    (! return {result}) ]
