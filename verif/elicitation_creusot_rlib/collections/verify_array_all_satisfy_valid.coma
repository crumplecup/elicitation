  {[@stop_split] [@expl:new ensures] ([@stop_split] [@expl:new result type invariant] [%#sintegers] inv_Result_I32Positive_ValidationError result)
    /\ ([@stop_split] [@expl:new ensures #0] [%#sextern_specs] Int32.to_int value > 0
      -> match result with
